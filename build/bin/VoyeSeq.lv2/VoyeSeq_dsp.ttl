@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix dg:    <http://www.darkglass.com/lv2/ns#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix mod:   <http://moddevices.com/ns/mod#> .
@prefix opts:  <http://lv2plug.in/ns/ext/options#> .
@prefix pg:    <http://lv2plug.in/ns/ext/port-groups#> .
@prefix patch: <http://lv2plug.in/ns/ext/patch#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rsz:   <http://lv2plug.in/ns/ext/resize-port#> .
@prefix spdx:  <http://spdx.org/rdf/terms#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix unit:  <http://lv2plug.in/ns/extensions/units#> .

<https://github.com/yellius/VoyeSeq#pattern_names>
    a lv2:Parameter ;
    rdfs:label "" ;
    rdfs:range atom:String .

<https://github.com/yellius/VoyeSeq#pattern_data>
    a lv2:Parameter ;
    rdfs:label "" ;
    rdfs:range atom:String .

<https://github.com/yellius/VoyeSeq>
    a lv2:Plugin, doap:Project ;

    lv2:extensionData opts:interface ,
                      <http://lv2plug.in/ns/ext/state#interface> ,
                      <http://lv2plug.in/ns/ext/worker#interface> ;

    lv2:optionalFeature <http://lv2plug.in/ns/lv2core#hardRTCapable> ,
                        <http://lv2plug.in/ns/ext/buf-size#boundedBlockLength> ,
                        <http://lv2plug.in/ns/ext/state#mapPath> ,
                        <http://lv2plug.in/ns/ext/state#freePath> ;

    lv2:requiredFeature opts:options ,
                        <http://lv2plug.in/ns/ext/urid#map> ,
                        <http://lv2plug.in/ns/ext/worker#schedule> ;

    opts:supportedOption <http://lv2plug.in/ns/ext/buf-size#nominalBlockLength> ,
                         <http://lv2plug.in/ns/ext/buf-size#maxBlockLength> ,
                         <http://lv2plug.in/ns/ext/parameters#sampleRate> ;

    patch:writable <https://github.com/yellius/VoyeSeq#pattern_names> ;
    patch:writable <https://github.com/yellius/VoyeSeq#pattern_data> ;

    ui:ui <https://github.com/yellius/VoyeSeq#DPF_UI> ;

    lv2:port [
        a lv2:InputPort, atom:AtomPort ;
        lv2:index 0 ;
        lv2:name "Events Input" ;
        lv2:symbol "lv2_events_in" ;
        rsz:minimumSize 2048 ;
        atom:bufferType atom:Sequence ;
        atom:supports atom:String ;
        atom:supports midi:MidiEvent ;
        atom:supports <http://lv2plug.in/ns/ext/time#Position> ;
        atom:supports <http://lv2plug.in/ns/ext/patch#Message> ;
        lv2:designation lv2:control ;
    ] ;

    lv2:port [
        a lv2:OutputPort, atom:AtomPort ;
        lv2:index 1 ;
        lv2:name "Events Output" ;
        lv2:symbol "lv2_events_out" ;
        rsz:minimumSize 2048 ;
        atom:bufferType atom:Sequence ;
        atom:supports atom:String ;
        atom:supports midi:MidiEvent ;
        atom:supports <http://lv2plug.in/ns/ext/patch#Message> ;
        lv2:designation lv2:control ;
    ] ;

    lv2:port [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 2 ;
        lv2:name "Note" ;
        lv2:symbol "lv2_port_1" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 3 ;
        lv2:name "BPM" ;
        lv2:symbol "lv2_port_2" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 4 ;
        lv2:name "Transport" ;
        lv2:symbol "lv2_port_3" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 5 ;
        lv2:name "Bar" ;
        lv2:symbol "lv2_port_4" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 6 ;
        lv2:name "Beat" ;
        lv2:symbol "lv2_port_5" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 7 ;
        lv2:name "Tick" ;
        lv2:symbol "lv2_port_6" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 8 ;
        lv2:name "TicksPerBeat" ;
        lv2:symbol "lv2_port_7" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 9 ;
        lv2:name "SigNum" ;
        lv2:symbol "lv2_port_8" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 10 ;
        lv2:name "SigDen" ;
        lv2:symbol "lv2_port_9" ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ;

    mod:brand "DISTRHO" ;
    mod:label "VoyeSeq" ;

    doap:name "VoyeSeq" ;
    doap:license <http://opensource.org/licenses/gpl-license> ;

    doap:maintainer [
        foaf:name "Yellius" ;
    ] ;

    lv2:microVersion 0 ;
    lv2:minorVersion 2 .
