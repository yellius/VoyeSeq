@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix dg:    <http://www.darkglass.com/lv2/ns#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix mod:   <http://moddevices.com/ns/mod#> .
@prefix opts:  <http://lv2plug.in/ns/ext/options#> .
@prefix pg:    <http://lv2plug.in/ns/ext/port-groups#> .
@prefix patch: <http://lv2plug.in/ns/ext/patch#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rsz:   <http://lv2plug.in/ns/ext/resize-port#> .
@prefix spdx:  <http://spdx.org/rdf/terms#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix unit:  <http://lv2plug.in/ns/extensions/units#> .

<http://distrho.sf.net/examples/States#top-left>
    a lv2:Parameter ;
    rdfs:label "Top Left" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#top-center>
    a lv2:Parameter ;
    rdfs:label "Top Center" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#top-right>
    a lv2:Parameter ;
    rdfs:label "Top Right" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#middle-left>
    a lv2:Parameter ;
    rdfs:label "Middle Left" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#middle-center>
    a lv2:Parameter ;
    rdfs:label "Middle Center" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#middle-right>
    a lv2:Parameter ;
    rdfs:label "Middle Right" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#bottom-left>
    a lv2:Parameter ;
    rdfs:label "Bottom Left" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#bottom-center>
    a lv2:Parameter ;
    rdfs:label "Bottom Center" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States#bottom-right>
    a lv2:Parameter ;
    rdfs:label "Bottom Right" ;
    rdfs:range atom:String .

<http://distrho.sf.net/examples/States>
    a lv2:Plugin, doap:Project ;

    lv2:extensionData opts:interface ,
                      <http://lv2plug.in/ns/ext/state#interface> ,
                      <http://lv2plug.in/ns/ext/worker#interface> ,
                      <http://kxstudio.sf.net/ns/lv2ext/programs#Interface> ;

    lv2:optionalFeature <http://lv2plug.in/ns/lv2core#hardRTCapable> ,
                        <http://lv2plug.in/ns/ext/buf-size#boundedBlockLength> ,
                        <http://lv2plug.in/ns/ext/state#mapPath> ,
                        <http://lv2plug.in/ns/ext/state#freePath> ;

    lv2:requiredFeature opts:options ,
                        <http://lv2plug.in/ns/ext/urid#map> ,
                        <http://lv2plug.in/ns/ext/worker#schedule> ;

    opts:supportedOption <http://lv2plug.in/ns/ext/buf-size#nominalBlockLength> ,
                         <http://lv2plug.in/ns/ext/buf-size#maxBlockLength> ,
                         <http://lv2plug.in/ns/ext/parameters#sampleRate> ;

    patch:writable <http://distrho.sf.net/examples/States#top-left> ;
    patch:writable <http://distrho.sf.net/examples/States#top-center> ;
    patch:writable <http://distrho.sf.net/examples/States#top-right> ;
    patch:writable <http://distrho.sf.net/examples/States#middle-left> ;
    patch:writable <http://distrho.sf.net/examples/States#middle-center> ;
    patch:writable <http://distrho.sf.net/examples/States#middle-right> ;
    patch:writable <http://distrho.sf.net/examples/States#bottom-left> ;
    patch:writable <http://distrho.sf.net/examples/States#bottom-center> ;
    patch:writable <http://distrho.sf.net/examples/States#bottom-right> ;

    ui:ui <http://distrho.sf.net/examples/States#DPF_UI> ;

    lv2:port [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 0 ;
        lv2:symbol "lv2_audio_in_1" ;
        lv2:name "Audio Input 1" ;
        pg:group <http://distrho.sf.net/examples/States#portGroup_dpf_stereo> ;
        lv2:designation pg:left ;
    ] ,
    [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 1 ;
        lv2:symbol "lv2_audio_in_2" ;
        lv2:name "Audio Input 2" ;
        pg:group <http://distrho.sf.net/examples/States#portGroup_dpf_stereo> ;
        lv2:designation pg:right ;
    ] ;

    lv2:port [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 2 ;
        lv2:symbol "lv2_audio_out_1" ;
        lv2:name "Audio Output 1" ;
        pg:group <http://distrho.sf.net/examples/States#portGroup_dpf_stereo> ;
        lv2:designation pg:left ;
    ] ,
    [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 3 ;
        lv2:symbol "lv2_audio_out_2" ;
        lv2:name "Audio Output 2" ;
        pg:group <http://distrho.sf.net/examples/States#portGroup_dpf_stereo> ;
        lv2:designation pg:right ;
    ] ;

    lv2:port [
        a lv2:InputPort, atom:AtomPort ;
        lv2:index 4 ;
        lv2:name "Events Input" ;
        lv2:symbol "lv2_events_in" ;
        rsz:minimumSize 2048 ;
        atom:bufferType atom:Sequence ;
        atom:supports atom:String ;
        atom:supports <http://lv2plug.in/ns/ext/patch#Message> ;
        lv2:designation lv2:control ;
    ] ;

    lv2:port [
        a lv2:OutputPort, atom:AtomPort ;
        lv2:index 5 ;
        lv2:name "Events Output" ;
        lv2:symbol "lv2_events_out" ;
        rsz:minimumSize 2048 ;
        atom:bufferType atom:Sequence ;
        atom:supports atom:String ;
        atom:supports <http://lv2plug.in/ns/ext/patch#Message> ;
        lv2:designation lv2:control ;
    ] ;

    rdfs:comment """Simple plugin to demonstrate state usage (including UI).
The plugin will be treated as an effect, but it will not change the host audio.""" ;

    mod:brand "DISTRHO" ;
    mod:label "States" ;

    doap:name "States" ;
    doap:license <http://spdx.org/licenses/ISC.html> ;

    doap:maintainer [
        foaf:name "DISTRHO" ;
        foaf:homepage <https://github.com/DISTRHO/DPF> ;
    ] ;

    lv2:microVersion 0 ;
    lv2:minorVersion 2 .

<http://distrho.sf.net/examples/States#portGroup_dpf_stereo>
    a pg:Group , pg:StereoGroup ;
    lv2:name "Stereo" ;
    lv2:symbol "dpf_stereo" .
